# Backend-local `.env` (loaded when cwd is `backend/` during `uvicorn`).
# For a full template, see the repository root `.env.example`.

LLM_PROVIDER=openai
OPENAI_API_KEY=
# Optional Anthropic fallback: set LLM_PROVIDER=anthropic and:
# CLAUDE_API_KEY=

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/contextlens
REDIS_URL=redis://localhost:6379/0

GENERATION_MODEL_NAME=gpt-4o-mini
EVALUATION_MODEL_NAME=gpt-4o-mini

OPENAI_INPUT_USD_PER_MILLION_TOKENS=0.15
OPENAI_OUTPUT_USD_PER_MILLION_TOKENS=0.60
ANTHROPIC_INPUT_USD_PER_MILLION_TOKENS=3.0
ANTHROPIC_OUTPUT_USD_PER_MILLION_TOKENS=15.0
