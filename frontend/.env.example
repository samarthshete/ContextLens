# Vite dev server: where to proxy `/api/*` (see vite.config.ts).
#
# Default (no file needed): http://127.0.0.1:8002 — matches:
#   - `docker compose` **backend** service (host **8002** → container 8000)
#   - local `uvicorn ... --port 8002` when NOT using Docker for the API
#
# Do NOT run Docker backend and local uvicorn both on port 8002.
#
# Override only if your API listens elsewhere, e.g.:
# BACKEND_PROXY_TARGET=http://127.0.0.1:8000
#
# Copy to `.env.development.local` (gitignored) to override.
#
# Hosted SPA (different origin than API) — set at build time:
# VITE_API_BASE=https://your-api.example.com/api/v1
#
# Write key for optional API protection is entered in the UI (sessionStorage), not here.
