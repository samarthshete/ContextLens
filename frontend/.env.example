# Vite dev server only: origin of the FastAPI app for `/api` proxy.
# Default in vite.config.ts is http://127.0.0.1:8002 (common when uvicorn uses --port 8002).
# Docker Compose publishes the API on host port 8000 — then use:
# BACKEND_PROXY_TARGET=http://127.0.0.1:8000
#
# Copy to .env.development.local (gitignored) to override.
# BACKEND_PROXY_TARGET=http://127.0.0.1:8002
