# ContextLens Environment Variables
# Copy to .env and fill in values

# Database — host port depends on setup:
# - Docker Compose `db` service maps host 5433 → Postgres 5432 → use ...@localhost:5433/contextlens
# - Local Postgres on 5432 → use ...@localhost:5432/contextlens
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/contextlens

# Redis — required for eval_mode=full (RQ job queue)
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Upload directory (relative to app cwd)
UPLOAD_DIR=uploads

# LLM provider: openai (default) or anthropic
LLM_PROVIDER=openai

# API keys — set the one matching LLM_PROVIDER (OpenAI is default for full RAG)
OPENAI_API_KEY=
CLAUDE_API_KEY=

EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
GENERATION_MODEL_NAME=gpt-4o-mini
EVALUATION_MODEL_NAME=gpt-4o-mini

# OpenAI pricing (USD per 1M tokens) — used when LLM_PROVIDER=openai
OPENAI_INPUT_USD_PER_MILLION_TOKENS=0.15
OPENAI_OUTPUT_USD_PER_MILLION_TOKENS=0.60

# Anthropic pricing — used when LLM_PROVIDER=anthropic
# Optional: set both to 0 to leave evaluation_results.cost_usd NULL (no estimate)
ANTHROPIC_INPUT_USD_PER_MILLION_TOKENS=3.0
ANTHROPIC_OUTPUT_USD_PER_MILLION_TOKENS=15.0

# Frontend
VITE_API_BASE_URL=http://localhost:8000
