# ContextLens Environment Variables
# Copy to .env and fill in values

# Database (matches docker-compose default)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/contextlens

# Redis — required for eval_mode=full (RQ job queue)
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Upload directory (relative to app cwd)
UPLOAD_DIR=uploads

# LLM / Embedding
CLAUDE_API_KEY=
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
GENERATION_MODEL_NAME=claude-3-5-sonnet-latest
EVALUATION_MODEL_NAME=claude-3-5-sonnet-latest
# Optional: set both to 0 to leave evaluation_results.cost_usd NULL (no estimate)
ANTHROPIC_INPUT_USD_PER_MILLION_TOKENS=3.0
ANTHROPIC_OUTPUT_USD_PER_MILLION_TOKENS=15.0

# Frontend
VITE_API_BASE_URL=http://localhost:8000
